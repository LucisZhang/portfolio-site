# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/docs/phase2-public-review-artifacts/goal2-final/playwright-raw.json

# next.js
/.next/
/out/
/public/generated/
/public/duckdb/*
!/public/duckdb/README.md
!/public/duckdb/extensions/
!/public/duckdb/extensions/**

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude local artifacts (never commit)
.claude/logs/
.claude/backups/

# private review source for the explicitly generated, hash-bound assistant grounding
/docs/PROJECT_DOSSIER.md
