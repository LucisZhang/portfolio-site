      "page_count",
      "page_dimensions",
      "extractable_text_empty",
      "annotations_empty",
      "known_terms_absent",
      "original_metadata_absent",
      "burn_in_pixels"
    ],
    "fail_closed": true
  },
  "runtime_packages": {
    "tesseract.js": "7.0.0",
    "pdfjs-dist": "6.1.200",
    "pdf-lib": "1.17.1",
    "@tesseract.js-data/eng": "1.0.0",
    "@tesseract.js-data/chi_sim": "1.0.0"
  }
