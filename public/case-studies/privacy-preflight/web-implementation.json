  "source_evidence": false,
  "fixture_policy": "All bundled examples are fixed and fictional. User files are never committed.",
  "processing_boundary": {
    "server_upload": false,
    "third_party_ocr": false,
    "content_web_storage": false,
    "runtime_assets": "same_origin_get_only"
  },
  "limits": {
    "image_bytes": 15728640,
